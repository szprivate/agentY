#!/usr/bin/env python3
"""Remove a template from the custom templates index.

Usage: ./remove_workflow TEMPLATE_NAME [--index-path PATH]

This script calls `src.utils.workflow_parser.workflow_remove`.
"""
import argparse
import sys
from pathlib import Path

from src.utils.workflow_parser import workflow_remove, _custom_index_path


def main(argv: list[str] | None = None) -> int:
    argv = list(argv) if argv is not None else sys.argv[1:]
    parser = argparse.ArgumentParser(description="Remove a workflow template from index.json")
    parser.add_argument("name", help="Template name to remove (the 'name' key in index.json)")
    parser.add_argument("--index-path", default="", help="Optional path to index.json")
    args = parser.parse_args(argv)

    index_path = Path(args.index_path) if args.index_path else None
    try:
        target = workflow_remove(args.name, index_path=index_path)
        print(f"Updated index: {target}")
        return 0
    except Exception as exc:
        print(f"Error removing template '{args.name}': {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
