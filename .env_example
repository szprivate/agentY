# .env_example — copy to .env and fill in your values.
# .env is git-ignored; this file is tracked as a reference.

HF_TOKEN=hf_...
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
ANTHROPIC_API_KEY=sk-ant-...
COMFYUI_API_KEY=comfyui-...

# To link to chainlit:
DATABASE_URL=postgresql://root:root@localhost:5432/postgres

# MinIO / S3 storage for Chainlit file uploads
BUCKET_NAME=chainlit
APP_AWS_REGION=us-east-1
APP_AWS_ACCESS_KEY=minioadmin
APP_AWS_SECRET_KEY=minioadmin
DEV_AWS_ENDPOINT=http://localhost:9000
CHAINLIT_USERNAME=yourname
CHAINLIT_PASSWORD=yourpassword
CHAINLIT_AUTH_SECRET="create your auth token via CLI: chainlit create-secret"